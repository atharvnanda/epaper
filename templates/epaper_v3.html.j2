<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aaj Tak Epaper - English Edition - {{ date }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #1a1a2e;
      font-family: 'Source Serif 4', Georgia, 'Times New Roman', serif;
      color: #1a1a1a;
    }

    /* -- Header -- */
    .header {
      background: linear-gradient(135deg, #c0392b, #e74c3c);
      color: white;
      text-align: center;
      padding: 16px 20px;
      font-size: 20px;
      font-weight: bold;
      letter-spacing: 1px;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 12px rgba(0,0,0,0.4);
    }
    .header span {
      font-weight: normal;
      font-size: 14px;
      opacity: 0.85;
      margin-left: 14px;
    }

    /* -- Toggle button -- */
    .toggle-btn {
      position: fixed;
      top: 60px;
      right: 20px;
      z-index: 200;
      background: rgba(0,0,0,0.7);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.2);
      padding: 8px 16px;
      border-radius: 20px;
      cursor: pointer;
      font-size: 13px;
      font-family: 'Inter', Arial, sans-serif;
      transition: all 0.2s;
      backdrop-filter: blur(6px);
    }
    .toggle-btn:hover { background: rgba(0,0,0,0.9); }

    /* -- Carousel -- */
    .carousel-wrapper {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      min-height: calc(100vh - 52px);
      padding: 24px 20px;
      position: relative;
    }

    .page-slide { display: none; }
    .page-slide.active { display: block; }

    .page-container {
      position: relative;
      display: inline-block;
      box-shadow: 0 6px 30px rgba(0,0,0,0.6);
      background: white;
      max-width: 100%;
    }

    .page-container img {
      display: block;
      width: 1120px;
      max-width: 100%;
      height: auto;
    }

    /* ============================================
       TEXT BLOCK OVERLAYS -- SOLID, OPAQUE, FIXED
       ============================================ */
    .text-block {
      position: absolute;
      overflow: hidden;
      padding: 3px 5px;
      box-sizing: border-box;
      transition: opacity 0.25s ease;
      word-break: break-word;
      hyphens: auto;
    }

    /* --- HEADLINE: large bold serif --- */
    .text-block.role-headline {
      font-family: 'Playfair Display', 'Georgia', serif;
      font-weight: 900;
      font-size: 22px;
      letter-spacing: -0.01em;
      color: #111;
      line-height: 1.12;
      display: flex;
      align-items: flex-start;
      text-align: left;
    }

    /* --- SUBHEADLINE: medium bold sans --- */
    .text-block.role-subheadline {
      font-family: 'Inter', Arial, sans-serif;
      font-weight: 700;
      font-size: 13px;
      color: #c0392b;
      line-height: 1.2;
      display: flex;
      align-items: flex-start;
    }

    /* --- BODY: clean readable serif --- */
    .text-block.role-body {
      font-family: 'Source Serif 4', Georgia, serif;
      font-weight: 400;
      font-size: 10.5px;
      color: #222;
      line-height: 1.4;
      text-align: left;
    }

    /* --- BYLINE: small italic sans --- */
    .text-block.role-byline {
      font-family: 'Inter', Arial, sans-serif;
      font-weight: 600;
      font-size: 10px;
      font-style: italic;
      color: #c0392b;
      line-height: 1.25;
    }

    /* --- CAPTION: small sans --- */
    .text-block.role-caption {
      font-family: 'Inter', Arial, sans-serif;
      font-weight: 400;
      font-size: 9px;
      font-style: italic;
      color: #555;
      line-height: 1.2;
    }

    .overlays-hidden .text-block {
      opacity: 0 !important;
      pointer-events: none;
    }

    /* -- Navigation -- */
    .nav-btn {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(0,0,0,0.55);
      color: white;
      border: none;
      font-size: 34px;
      width: 52px;
      height: 84px;
      cursor: pointer;
      z-index: 50;
      border-radius: 6px;
      transition: background 0.2s;
      backdrop-filter: blur(4px);
    }
    .nav-btn:hover { background: rgba(0,0,0,0.85); }
    .prev-btn { left: 10px; }
    .next-btn { right: 10px; }

    /* -- Page indicator -- */
    .page-indicator {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0,0,0,0.75);
      color: white;
      padding: 10px 22px;
      border-radius: 24px;
      font-size: 14px;
      z-index: 50;
      font-family: 'Inter', Arial, sans-serif;
      backdrop-filter: blur(6px);
    }

    .page-dots { display: flex; gap: 8px; align-items: center; }
    .page-dot {
      width: 10px; height: 10px; border-radius: 50%;
      background: rgba(255,255,255,0.35);
      cursor: pointer; transition: all 0.2s;
    }
    .page-dot.active { background: white; transform: scale(1.3); }

    .page-label {
      position: fixed; bottom: 60px; left: 50%;
      transform: translateX(-50%);
      color: rgba(255,255,255,0.6);
      font-size: 13px; font-family: 'Inter', Arial, sans-serif; z-index: 50;
    }

    @media (max-width: 1200px) {
      .page-container img { width: 100vw; }
    }
  </style>
</head>
<body>

  <div class="header">
    AAJ TAK - English Edition <span>{{ date }}</span>
  </div>

  <button class="toggle-btn" onclick="toggleOverlays()">Hide Overlays</button>
  <button class="nav-btn prev-btn" onclick="changePage(-1)">&#8249;</button>
  <button class="nav-btn next-btn" onclick="changePage(1)">&#8250;</button>

  <div class="carousel-wrapper">
    {% for page in pages %}
    <div class="page-slide{% if loop.first %} active{% endif %}" id="page-{{ page.page_num }}">
      <div class="page-container">
        <img src="{{ page.image_src }}" alt="Page {{ page.page_num }}">

        {# Per-block overlays: only text gets covered, images stay visible #}
        {% for art in page.articles %}
          {% for blk in art.get("render_blocks", []) %}
            {% if blk.en_text %}
            <div class="text-block role-{{ blk.role }}"
                 style="top: {{ '%.3f'|format(blk.top_pct) }}%;
                        left: {{ '%.3f'|format(blk.left_pct) }}%;
                        width: {{ '%.3f'|format(blk.width_pct) }}%;
                        height: {{ '%.3f'|format(blk.height_pct) }}%;
                        background: {{ blk.bg_color }};">
              {{ blk.en_text }}
            </div>
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>

  <div class="page-label" id="pageLabel">Page 1 of {{ pages|length }}</div>
  <div class="page-indicator">
    <div class="page-dots">
      {% for page in pages %}
      <div class="page-dot{% if loop.first %} active{% endif %}"
           onclick="goToPage({{ loop.index0 }})"></div>
      {% endfor %}
    </div>
  </div>

  <script>
    let currentPage = 0;
    const slides = document.querySelectorAll('.page-slide');
    const dots = document.querySelectorAll('.page-dot');
    const totalPages = slides.length;
    const pageLabel = document.getElementById('pageLabel');

    function changePage(delta) {
      currentPage = (currentPage + delta + totalPages) % totalPages;
      updateCarousel();
    }
    function goToPage(idx) { currentPage = idx; updateCarousel(); }

    function updateCarousel() {
      slides.forEach((s, i) => s.classList.toggle('active', i === currentPage));
      dots.forEach((d, i) => d.classList.toggle('active', i === currentPage));
      pageLabel.textContent = `Page ${currentPage + 1} of ${totalPages}`;
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') changePage(1);
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') changePage(-1);
    });

    let overlaysVisible = true;
    function toggleOverlays() {
      overlaysVisible = !overlaysVisible;
      document.querySelectorAll('.page-container').forEach(c => {
        c.classList.toggle('overlays-hidden', !overlaysVisible);
      });
      document.querySelector('.toggle-btn').textContent =
        overlaysVisible ? 'Hide Overlays' : 'Show Overlays';
    }
  </script>
</body>
</html>
