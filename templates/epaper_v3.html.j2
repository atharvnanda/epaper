<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aaj Tak Epaper - English Edition - {{ date }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #1a1a2e;
      font-family: Georgia, 'Times New Roman', serif;
      color: #1a1a1a;
    }

    /* -- Header -- */
    .header {
      background: linear-gradient(135deg, #c0392b, #e74c3c);
      color: white;
      text-align: center;
      padding: 16px 20px;
      font-size: 20px;
      font-weight: bold;
      letter-spacing: 1px;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 12px rgba(0,0,0,0.4);
    }
    .header span {
      font-weight: normal;
      font-size: 14px;
      opacity: 0.85;
      margin-left: 14px;
    }

    /* -- Toggle button -- */
    .toggle-btn {
      position: fixed;
      top: 60px;
      right: 20px;
      z-index: 200;
      background: rgba(0,0,0,0.7);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.2);
      padding: 8px 16px;
      border-radius: 20px;
      cursor: pointer;
      font-size: 13px;
      font-family: Arial, sans-serif;
      transition: all 0.2s;
      backdrop-filter: blur(6px);
    }
    .toggle-btn:hover { background: rgba(0,0,0,0.9); }

    /* -- Carousel -- */
    .carousel-wrapper {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      min-height: calc(100vh - 52px);
      padding: 24px 20px;
      position: relative;
    }

    .page-slide { display: none; }
    .page-slide.active { display: block; }

    .page-container {
      position: relative;
      display: inline-block;
      box-shadow: 0 6px 30px rgba(0,0,0,0.6);
      background: white;
      max-width: 100%;
    }

    .page-container img {
      display: block;
      width: 1120px;
      max-width: 100%;
      height: auto;
    }

    /* -- Text block overlays (per-block, not per-article) -- */
    .text-block {
      position: absolute;
      overflow: hidden;
      padding: 2px 4px;
      box-sizing: border-box;
      transition: opacity 0.25s ease;
      word-break: break-word;
      hyphens: auto;
    }

    /* Role-specific styling */
    .text-block.role-headline {
      background: rgba(255, 253, 248, 0.97);
      font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;
      font-weight: 900;
      letter-spacing: 0.01em;
      color: #111;
      line-height: 1.1;
      display: flex;
      align-items: center;
      text-align: left;
    }

    .text-block.role-subheadline {
      background: rgba(255, 253, 248, 0.96);
      font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;
      font-weight: 700;
      color: #c0392b;
      line-height: 1.15;
      display: flex;
      align-items: center;
    }

    .text-block.role-body {
      background: rgba(255, 253, 248, 0.96);
      font-family: Georgia, 'Times New Roman', serif;
      font-weight: 400;
      color: #222;
      line-height: 1.38;
      text-align: justify;
    }

    .text-block.role-byline {
      background: rgba(255, 253, 248, 0.90);
      font-family: Arial, sans-serif;
      font-weight: 600;
      font-style: italic;
      color: #555;
      line-height: 1.2;
    }

    .text-block.role-caption {
      background: rgba(255, 253, 248, 0.93);
      font-family: Arial, sans-serif;
      font-weight: 400;
      font-style: italic;
      color: #444;
      line-height: 1.25;
    }

    .overlays-hidden .text-block {
      opacity: 0 !important;
      pointer-events: none;
    }

    /* -- Navigation -- */
    .nav-btn {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(0,0,0,0.55);
      color: white;
      border: none;
      font-size: 34px;
      width: 52px;
      height: 84px;
      cursor: pointer;
      z-index: 50;
      border-radius: 6px;
      transition: background 0.2s;
      backdrop-filter: blur(4px);
    }
    .nav-btn:hover { background: rgba(0,0,0,0.85); }
    .prev-btn { left: 10px; }
    .next-btn { right: 10px; }

    /* -- Page indicator -- */
    .page-indicator {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0,0,0,0.75);
      color: white;
      padding: 10px 22px;
      border-radius: 24px;
      font-size: 14px;
      z-index: 50;
      font-family: Arial, sans-serif;
      backdrop-filter: blur(6px);
    }

    .page-dots { display: flex; gap: 8px; align-items: center; }
    .page-dot {
      width: 10px; height: 10px; border-radius: 50%;
      background: rgba(255,255,255,0.35);
      cursor: pointer; transition: all 0.2s;
    }
    .page-dot.active { background: white; transform: scale(1.3); }

    .page-label {
      position: fixed; bottom: 60px; left: 50%;
      transform: translateX(-50%);
      color: rgba(255,255,255,0.6);
      font-size: 13px; font-family: Arial, sans-serif; z-index: 50;
    }

    @media (max-width: 1200px) {
      .page-container img { width: 100vw; }
    }
  </style>
</head>
<body>

  <div class="header">
    AAJ TAK - English Edition <span>{{ date }}</span>
  </div>

  <button class="toggle-btn" onclick="toggleOverlays()">Hide Overlays</button>
  <button class="nav-btn prev-btn" onclick="changePage(-1)">&#8249;</button>
  <button class="nav-btn next-btn" onclick="changePage(1)">&#8250;</button>

  <div class="carousel-wrapper">
    {% for page in pages %}
    <div class="page-slide{% if loop.first %} active{% endif %}" id="page-{{ page.page_num }}">
      <div class="page-container">
        <img src="images/page_{{ page.page_num }}.jpg" alt="Page {{ page.page_num }}">

        {# Per-block overlays: only text gets covered, images stay visible #}
        {% for art in page.articles %}
          {% for blk in art.get("render_blocks", []) %}
            {% if blk.en_text %}
            <div class="text-block role-{{ blk.role }}"
                 style="top: {{ '%.3f'|format(blk.top_pct) }}%;
                        left: {{ '%.3f'|format(blk.left_pct) }}%;
                        width: {{ '%.3f'|format(blk.width_pct) }}%;
                        height: {{ '%.3f'|format(blk.height_pct) }}%;"
                 data-text="{{ blk.en_text|e }}"
                 data-role="{{ blk.role }}"
                 data-font-size="{{ blk.font_size }}"
                 data-max-font="{{ blk.max_font_size }}">
            </div>
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>

  <div class="page-label" id="pageLabel">Page 1 of {{ pages|length }}</div>
  <div class="page-indicator">
    <div class="page-dots">
      {% for page in pages %}
      <div class="page-dot{% if loop.first %} active{% endif %}"
           onclick="goToPage({{ loop.index0 }})"></div>
      {% endfor %}
    </div>
  </div>

  <script>
    let currentPage = 0;
    const slides = document.querySelectorAll('.page-slide');
    const dots = document.querySelectorAll('.page-dot');
    const totalPages = slides.length;
    const pageLabel = document.getElementById('pageLabel');

    function changePage(delta) {
      currentPage = (currentPage + delta + totalPages) % totalPages;
      updateCarousel();
    }
    function goToPage(idx) { currentPage = idx; updateCarousel(); }

    function updateCarousel() {
      slides.forEach((s, i) => s.classList.toggle('active', i === currentPage));
      dots.forEach((d, i) => d.classList.toggle('active', i === currentPage));
      pageLabel.textContent = `Page ${currentPage + 1} of ${totalPages}`;
      requestAnimationFrame(() => fillOverlays(slides[currentPage]));
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') changePage(1);
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') changePage(-1);
    });

    let overlaysVisible = true;
    function toggleOverlays() {
      overlaysVisible = !overlaysVisible;
      document.querySelectorAll('.page-container').forEach(c => {
        c.classList.toggle('overlays-hidden', !overlaysVisible);
      });
      document.querySelector('.toggle-btn').textContent =
        overlaysVisible ? 'Hide Overlays' : 'Show Overlays';
    }

    /* -- Auto-fit text into a block-level overlay -- */
    function autoFitText(el) {
      const text = (el.dataset.text || '').trim();
      if (!text) return false;

      const boxW = el.offsetWidth;
      const boxH = el.offsetHeight;
      if (boxW < 5 || boxH < 5) return false;

      const role = el.dataset.role;
      const pdfFontSize = parseFloat(el.dataset.maxFont) || 15;

      // Compute starting English font size from PDF font metadata
      let fontSize;
      if (role === 'headline') {
        fontSize = Math.min(pdfFontSize * 0.55, boxH * 0.85, 40);
        fontSize = Math.max(fontSize, 14);
      } else if (role === 'subheadline') {
        fontSize = Math.min(pdfFontSize * 0.50, boxH * 0.7, 24);
        fontSize = Math.max(fontSize, 10);
      } else if (role === 'byline') {
        fontSize = Math.min(pdfFontSize * 0.48, boxH * 0.8, 14);
        fontSize = Math.max(fontSize, 8);
      } else if (role === 'caption') {
        fontSize = Math.min(pdfFontSize * 0.48, boxH * 0.75, 13);
        fontSize = Math.max(fontSize, 7.5);
      } else {
        // body
        fontSize = Math.min(pdfFontSize * 0.52, boxH * 0.18, 15);
        fontSize = Math.max(fontSize, 8);
      }

      el.style.fontSize = fontSize + 'px';
      el.textContent = text;

      // Shrink to fit
      const maxTries = (role === 'body') ? 5 : 20;
      const shrinkFactor = (role === 'body') ? 0.95 : 0.92;
      const minFont = (role === 'body') ? 7.5 : 6;
      let tries = 0;
      while (el.scrollHeight > boxH + 2 && fontSize > minFont && tries < maxTries) {
        fontSize *= shrinkFactor;
        el.style.fontSize = fontSize + 'px';
        tries++;
      }

      // If still overflowing, use CSS truncation
      if (el.scrollHeight > boxH + 2) {
        el.style.overflow = 'hidden';
        el.style.textOverflow = 'ellipsis';
        el.style.display = '-webkit-box';
        el.style.webkitLineClamp = Math.max(1, Math.floor(boxH / (fontSize * 1.4)));
        el.style.webkitBoxOrient = 'vertical';
      }

      return true;
    }

    function fillOverlays(slideEl) {
      if (!slideEl) return;
      slideEl.querySelectorAll('.text-block').forEach(el => {
        if (el.dataset.filled) return;
        if (autoFitText(el)) {
          el.dataset.filled = '1';
        }
      });
    }

    // Fill first page + handle lazy image loads
    fillOverlays(slides[0]);
    document.querySelectorAll('.page-container img').forEach(img => {
      if (img.complete) return;
      img.addEventListener('load', () => {
        fillOverlays(img.closest('.page-slide'));
      });
    });
  </script>
</body>
</html>
